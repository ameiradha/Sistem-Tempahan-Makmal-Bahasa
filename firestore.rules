rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function emailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isTeacher() {
      return isSignedIn() && userExists() && getUserData().role == 'teacher';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Rules ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isOwner(userId);
    }

    // --- Settings Rules ---
    match /settings/global {
      allow read: if true; 
      allow write: if isTeacher();
    }

    match /settings/security {
      allow read, write: if isTeacher();
    }

    // --- Lab Rules ---
    match /labs/{labId} {
      allow read: if isSignedIn();
      allow write: if isTeacher();
    }

    // --- Booking Rules ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn(); 

      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && (request.resource.data.timeSlots is list || request.resource.data.timeSlot is string)
        && request.resource.data.keys().hasAll([
          'labId', 'labName', 'date', 'userId', 'userName', 
          'status', 'createdAt', 'teacherName', 'className', 'purpose'
        ]);

      allow update: if (isSignedIn() && (isOwner(resource.data.userId) || isTeacher()))
        ||
        // Allow Telegram Bot (Server-side) to update status via REST API
        // This is safe because bookingId is a long random string (acting as a secret)
        (request.auth == null 
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
          && request.resource.data.status in ['confirmed', 'rejected'])
      ;

      allow delete: if isTeacher(); 
    }
  }
}
