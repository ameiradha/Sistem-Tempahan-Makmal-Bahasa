{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Lab": {
      "title": "Lab",
      "description": "Computer lab details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "capacity": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Lab booking record",
      "type": "object",
      "properties": {
        "labId": { "type": "string" },
        "labName": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string" },
        "timeSlots": { "type": "array" },
        "purpose": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["labId", "userId", "status", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/labs/{labId}": {
      "schema": "Lab",
      "description": "Computer labs"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Lab bookings"
    },
    "/settings/global": {
      "schema": { "type": "object" },
      "description": "Global app settings including Telegram token"
    }
  }
}
